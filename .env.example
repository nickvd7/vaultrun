# Copy to .env and fill in the REQUIRED values before starting.
#
# Generate strong secrets:
#   openssl rand -hex 32   → for MASTER_API_KEY and POSTGRES_PASSWORD

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
# Use "release" in production. "debug" logs request bodies and is noisy.
GIN_MODE=release
# Max requests per minute per client IP on authenticated routes. 0 = disabled.
RATE_LIMIT_PER_MIN=120

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser clients.
# Leave empty to block all cross-origin requests (recommended for API-only use).
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,https://dashboard.example.com
CORS_ALLOWED_ORIGINS=

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED — change the password before deploying
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://vaultrun:change-me-strong-password@localhost:5432/vaultrun?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
# TLS for Postgres — strongly recommended in production.
# DB_SSL_MODE overrides any sslmode already in DATABASE_URL.
# Options: disable|allow|prefer|require|verify-ca|verify-full
# Production recommendation: verify-full (with the CA cert below).
DB_SSL_MODE=
# Path to the PostgreSQL server CA certificate (required for verify-ca / verify-full).
DB_SSL_ROOT_CERT=
# Client certificate and key (required for mutual TLS).
DB_SSL_CERT=
DB_SSL_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
# Set a password for Redis in any non-localhost deployment
REDIS_PASSWORD=
REDIS_DB=0

# ── Docker sandbox ────────────────────────────────────────────────────────────
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_CONTAINER_PREFIX=vaultrun
DOCKER_DEFAULT_IMAGE=python:3.12-slim
DOCKER_IDLE_TIMEOUT_MINS=30
# Optional allowlist of permitted container images (comma-separated).
# Leave empty to allow any image. Restrict this in production.
# Example: DOCKER_IMAGE_ALLOWLIST=python:3.12-slim,node:20-slim
DOCKER_IMAGE_ALLOWLIST=
# Seccomp profile: leave unset to use the embedded vaultrun profile (recommended).
# Set to "default" to use the Docker daemon's built-in profile.
# Set to an absolute file path to load a custom profile.
DOCKER_SECCOMP_PROFILE=
# Cosign image signature verification (strongly recommended in production).
# Set to the path of your cosign public key file (PEM format).
# When set, CreateSandbox refuses any image whose signature cannot be verified.
# Leave empty to disable (default — insecure for production).
COSIGN_PUBLIC_KEY=

# ── Session resource limits ───────────────────────────────────────────────────
MAX_SESSION_CPU=8
MAX_SESSION_MEMORY_MB=8192
MAX_SESSION_TIMEOUT_SEC=86400

# ── Workspace ─────────────────────────────────────────────────────────────────
WORKSPACE_BASE_DIR=/data/workspaces
MAX_FILE_MB=100
MAX_OUTPUT_MB=10
# Total workspace size cap per session (0 = unlimited)
MAX_WORKSPACE_MB=0

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
# Used only to create the first API key. Rotate or disable after bootstrapping.
MASTER_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Audit log retention — entries older than N days are deleted by the cleanup sweep.
# 0 = keep forever. Default: 90 days.
AUDIT_LOG_RETENTION_DAYS=90
STOP_CONTAINERS_ON_SHUTDOWN=false

# ── Migrations ────────────────────────────────────────────────────────────────
MIGRATIONS_PATH=migrations

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── CLI / SDK ─────────────────────────────────────────────────────────────────
VAULTRUN_API_URL=http://localhost:8080
VAULTRUN_API_KEY=
