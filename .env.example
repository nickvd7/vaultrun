# Copy to .env and fill in the REQUIRED values before starting.
#
# Generate strong secrets:
#   openssl rand -hex 32   → for MASTER_API_KEY and POSTGRES_PASSWORD

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
# Use "release" in production. "debug" logs request bodies and is noisy.
GIN_MODE=release
# Max requests per minute per client IP on authenticated routes. 0 = disabled.
RATE_LIMIT_PER_MIN=120
# Per-actor (API key) rate limit. 0 = inherit RATE_LIMIT_PER_MIN. -1 = disabled.
ACTOR_RATE_LIMIT_PER_MIN=0
# TLS — choose one of the three modes:
#
# 1. Static cert/key files (e.g. from your own CA or Certbot):
TLS_CERT_FILE=
TLS_KEY_FILE=
#
# 2. ACME / Let's Encrypt (auto-obtain + auto-renew):
#    Requires port 80+443 reachable and a public hostname. Takes precedence over TLS_CERT_FILE.
ACME_DOMAIN=
ACME_CACHE_DIR=/data/acme-cache
#
# 3. Plain HTTP — leave all TLS settings empty and use a reverse proxy (Caddy, nginx, etc.)

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser clients.
# Leave empty to block all cross-origin requests (recommended for API-only use).
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,https://dashboard.example.com
CORS_ALLOWED_ORIGINS=

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED — change the password before deploying
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://vaultrun:change-me-strong-password@localhost:5432/vaultrun?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
# TLS for Postgres — strongly recommended in production.
# DB_SSL_MODE overrides any sslmode already in DATABASE_URL.
# Options: disable|allow|prefer|require|verify-ca|verify-full
# Production recommendation: verify-full (with the CA cert below).
DB_SSL_MODE=
# Path to the PostgreSQL server CA certificate (required for verify-ca / verify-full).
DB_SSL_ROOT_CERT=
# Client certificate and key (required for mutual TLS).
DB_SSL_CERT=
DB_SSL_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
# When set, the durable Redis Streams backend is used for async run jobs and
# they survive server restarts. Leave empty to use the in-memory queue (jobs
# lost on restart — fine for development but not recommended in production).
REDIS_ADDR=localhost:6379
# Set a password for Redis in any non-localhost deployment
REDIS_PASSWORD=
REDIS_DB=0
# Number of concurrent async-run worker goroutines (Redis Streams backend only).
ASYNC_WORKERS=4
# In-memory queue depth when REDIS_ADDR is not set. Jobs are lost on restart.
ASYNC_QUEUE_SIZE=256

# ── Docker sandbox ────────────────────────────────────────────────────────────
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_CONTAINER_PREFIX=vaultrun
DOCKER_DEFAULT_IMAGE=python:3.12-slim
DOCKER_IDLE_TIMEOUT_MINS=30
# Optional allowlist of permitted container images (comma-separated).
# Leave empty to allow any image. Restrict this in production.
# Example: DOCKER_IMAGE_ALLOWLIST=python:3.12-slim,node:20-slim
DOCKER_IMAGE_ALLOWLIST=
# Seccomp profile: leave unset to use the embedded vaultrun profile (recommended).
# Set to "default" to use the Docker daemon's built-in profile.
# Set to an absolute file path to load a custom profile.
DOCKER_SECCOMP_PROFILE=
# Cosign image signature verification (strongly recommended in production).
# Set to the path of your cosign public key file (PEM format).
# When set, CreateSandbox refuses any image whose signature cannot be verified.
# Leave empty to disable (default — insecure for production).
COSIGN_PUBLIC_KEY=

# ── Warm container pool ────────────────────────────────────────────────────────
# Number of pre-started containers to keep ready (0 = disabled).
# When WARM_POOL_SIZE>0 and WARM_POOL_IMAGE is set, session creation for that
# image returns immediately without docker pull+create latency.
WARM_POOL_SIZE=0
# Image to pre-start. Must match the image callers request.
WARM_POOL_IMAGE=

# ── GPU runner support ─────────────────────────────────────────────────────────
# Set to "all" to expose all NVIDIA GPUs, or a specific device ID (e.g. "GPU-uuid").
# Requires the NVIDIA Container Toolkit on the host.
# Callers set gpu_enabled=true when creating a session to request GPU access.
DOCKER_GPU_DEVICES=

# ── Session resource limits ───────────────────────────────────────────────────
MAX_SESSION_CPU=8
MAX_SESSION_MEMORY_MB=8192
MAX_SESSION_TIMEOUT_SEC=86400
# Maximum concurrent sessions per API key actor. 0 = unlimited.
MAX_SESSIONS_PER_ACTOR=20

# ── Workspace ─────────────────────────────────────────────────────────────────
WORKSPACE_BASE_DIR=/data/workspaces
MAX_FILE_MB=100
MAX_OUTPUT_MB=10
# Total workspace size cap per session (0 = unlimited)
MAX_WORKSPACE_MB=0
# Total artifact storage cap per actor/API-key in MB (0 = unlimited).
# Master key is always exempt. Prevents a single actor filling the disk.
MAX_ARTIFACT_STORAGE_MB=0

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
# Used only to create the first API key. Rotate or disable after bootstrapping.
MASTER_API_KEY=
# Path to a Rego policy file for per-command allow/deny decisions. Empty = AllowAll.
OPA_POLICY_FILE=

# ── Secrets broker ────────────────────────────────────────────────────────────
# Backend provider: "env" (default), "vault" (HashiCorp Vault), or "aws" (AWS Secrets Manager).
SECRETS_PROVIDER=env
# HashiCorp Vault (required when SECRETS_PROVIDER=vault)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=
VAULT_MOUNT=secret
VAULT_PATH=vaultrun
# AWS Secrets Manager (required when SECRETS_PROVIDER=aws)
# Uses standard AWS credentials (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN).
# AWS_REGION must also be set.
SECRETS_AWS_PREFIX=vaultrun/
# Env provider: prefix for secret env vars (VAULTRUN_SECRET_<NAME>).
# e.g. VAULTRUN_SECRET_DB_PASSWORD=hunter2 → secret name "DB_PASSWORD"

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
# HMAC-SHA256 key for signing async run callback payloads (X-VaultRun-Signature header).
# Generate with: openssl rand -hex 32. Empty = no signing (insecure for internet-facing callbacks).
WEBHOOK_SECRET=
# Audit log retention — entries older than N days are deleted by the cleanup sweep.
# 0 = keep forever. Default: 90 days.
AUDIT_LOG_RETENTION_DAYS=90
STOP_CONTAINERS_ON_SHUTDOWN=false
# SIEM / enterprise audit export: set to an HTTP endpoint to receive newline-delimited JSON.
# New audit entries are polled every 30s and POSTed as application/x-ndjson.
AUDIT_EXPORT_URL=
# Bearer token sent in Authorization header to the SIEM endpoint.
AUDIT_EXPORT_SECRET=

# ── Migrations ────────────────────────────────────────────────────────────────
MIGRATIONS_PATH=migrations

# ── SSO / OIDC ────────────────────────────────────────────────────────────────
# OIDC is enabled when OIDC_ISSUER_URL is set together with the client credentials.
# Supported providers: Okta, Azure AD, Google Workspace, Keycloak, Auth0, etc.
# After a successful login the server issues a signed session cookie and maps
# the user's identity to a VaultRun API key automatically.
#
OIDC_ISSUER_URL=
# Example values:
#   Okta:          https://your-org.okta.com/oauth2/default
#   Azure AD:      https://login.microsoftonline.com/<tenant-id>/v2.0
#   Google:        https://accounts.google.com
#   Keycloak:      https://keycloak.example.com/realms/<realm>
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Must match one of the allowed redirect URIs registered with the IdP.
# Example: https://api.example.com/auth/oidc/callback
OIDC_REDIRECT_URL=
# Space-separated OIDC scopes (default: openid,email,profile)
OIDC_SCOPES=openid,email,profile

# ── SSO / SAML 2.0 ────────────────────────────────────────────────────────────
# SAML is enabled when all three SAML_ vars below are set.
# Generate a self-signed SP cert+key:
#   openssl req -x509 -newkey rsa:2048 -keyout saml.key -out saml.crt -days 3650 -nodes
SAML_IDP_METADATA_URL=
# Example: https://your-org.okta.com/app/<app-id>/sso/saml/metadata
SAML_CERT_FILE=
SAML_KEY_FILE=
# Public root URL of this API server (used in SP metadata and ACS URL).
SAML_ROOT_URL=https://api.example.com
# SP entity ID (default: SAML_ROOT_URL/auth/saml/metadata)
SAML_ENTITY_ID=

# ── SSO session cookie ────────────────────────────────────────────────────────
# Required when OIDC or SAML is enabled. Signs the JWT session cookie.
# Generate with: openssl rand -hex 32
SSO_SESSION_SECRET=
# Session lifetime in hours (default: 24)
SSO_SESSION_MAX_AGE_HOURS=24
# Set to false only in local dev without TLS (default: true when TLS is active)
SSO_SESSION_SECURE=true

# ── Multi-region ──────────────────────────────────────────────────────────────
# Optional region tag included in /health responses and audit log entries.
# Useful for identifying which datacenter an alert originates from.
# Example values: us-east-1, eu-west-1, ap-southeast-1
REGION=
# Optional read-replica DSN for list/get queries (reduces load on the primary).
# When empty, all queries hit the primary. Format is the same as DATABASE_URL.
DATABASE_READ_URL=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
# Server-side proxy: used by /api/proxy/[...path] — NOT exposed to the browser
VAULTRUN_API_URL=http://localhost:8080
VAULTRUN_API_KEY=

# ── MCP server ────────────────────────────────────────────────────────────────
# Transport: "stdio" (default, Claude Desktop / Claude Code) or "http" (all other agents)
MCP_TRANSPORT=stdio
# Required when MCP_TRANSPORT=http
MCP_AUTH_TOKEN=
# Optional port for HTTP transport (default: 8081)
MCP_PORT=8081
# TLS for HTTP transport (both required to enable HTTPS on the MCP server)
MCP_TLS_CERT=
MCP_TLS_KEY=
# Allowed CORS origins for HTTP transport (comma-separated; default: * in dev)
MCP_ALLOWED_ORIGINS=
# Rate limit for HTTP transport (requests per minute per IP; default: 60)
MCP_RATE_LIMIT=60
# SQLite database path for sqlite_* MCP tools
MCP_SQLITE_PATH=
# PostgreSQL DSN for pg_* MCP tools
MCP_PG_DSN=
# MongoDB URI and database name for mongo_* MCP tools
MCP_MONGO_URI=
MCP_MONGO_DB=

# ── CI Runner ─────────────────────────────────────────────────────────────────
# GitHub personal access token for posting PR comments (repo scope required)
GITHUB_TOKEN=
# HMAC secret matching your GitHub webhook configuration
CI_WEBHOOK_SECRET=
# VaultRun API endpoint and key for the CI runner
CI_VAULTRUN_URL=http://localhost:8080
CI_VAULTRUN_KEY=
# Port the CI runner webhook listener binds to (default: 9090)
CI_PORT=9090
# Docker image used to run tests (default: python:3.12-slim)
CI_DEFAULT_IMAGE=python:3.12-slim
# Optional Slack / Teams webhook URLs for build notifications
CI_SLACK_WEBHOOK=
CI_TEAMS_WEBHOOK=

# ── CLI / SDK ─────────────────────────────────────────────────────────────────
VAULTRUN_BASE_URL=http://localhost:8080
