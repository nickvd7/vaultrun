# Copy to .env and fill in the REQUIRED values before starting.
#
# Generate strong secrets:
#   openssl rand -hex 32   → for MASTER_API_KEY and POSTGRES_PASSWORD

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
# Use "release" in production. "debug" logs request bodies and is noisy.
GIN_MODE=release
# Max requests per minute per client IP on authenticated routes. 0 = disabled.
RATE_LIMIT_PER_MIN=120
# Per-actor (API key) rate limit. 0 = inherit RATE_LIMIT_PER_MIN. -1 = disabled.
ACTOR_RATE_LIMIT_PER_MIN=0
# TLS: set both to enable HTTPS. Leave empty for plain HTTP (use a reverse proxy in production).
TLS_CERT_FILE=
TLS_KEY_FILE=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser clients.
# Leave empty to block all cross-origin requests (recommended for API-only use).
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,https://dashboard.example.com
CORS_ALLOWED_ORIGINS=

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED — change the password before deploying
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://vaultrun:change-me-strong-password@localhost:5432/vaultrun?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
# TLS for Postgres — strongly recommended in production.
# DB_SSL_MODE overrides any sslmode already in DATABASE_URL.
# Options: disable|allow|prefer|require|verify-ca|verify-full
# Production recommendation: verify-full (with the CA cert below).
DB_SSL_MODE=
# Path to the PostgreSQL server CA certificate (required for verify-ca / verify-full).
DB_SSL_ROOT_CERT=
# Client certificate and key (required for mutual TLS).
DB_SSL_CERT=
DB_SSL_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
# When set, the durable Redis Streams backend is used for async run jobs and
# they survive server restarts. Leave empty to use the in-memory queue (jobs
# lost on restart — fine for development but not recommended in production).
REDIS_ADDR=localhost:6379
# Set a password for Redis in any non-localhost deployment
REDIS_PASSWORD=
REDIS_DB=0
# Number of concurrent async-run worker goroutines (Redis Streams backend only).
ASYNC_WORKERS=4
# In-memory queue depth when REDIS_ADDR is not set. Jobs are lost on restart.
ASYNC_QUEUE_SIZE=256

# ── Docker sandbox ────────────────────────────────────────────────────────────
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_CONTAINER_PREFIX=vaultrun
DOCKER_DEFAULT_IMAGE=python:3.12-slim
DOCKER_IDLE_TIMEOUT_MINS=30
# Optional allowlist of permitted container images (comma-separated).
# Leave empty to allow any image. Restrict this in production.
# Example: DOCKER_IMAGE_ALLOWLIST=python:3.12-slim,node:20-slim
DOCKER_IMAGE_ALLOWLIST=
# Seccomp profile: leave unset to use the embedded vaultrun profile (recommended).
# Set to "default" to use the Docker daemon's built-in profile.
# Set to an absolute file path to load a custom profile.
DOCKER_SECCOMP_PROFILE=
# Cosign image signature verification (strongly recommended in production).
# Set to the path of your cosign public key file (PEM format).
# When set, CreateSandbox refuses any image whose signature cannot be verified.
# Leave empty to disable (default — insecure for production).
COSIGN_PUBLIC_KEY=

# ── Warm container pool ────────────────────────────────────────────────────────
# Number of pre-started containers to keep ready (0 = disabled).
# When WARM_POOL_SIZE>0 and WARM_POOL_IMAGE is set, session creation for that
# image returns immediately without docker pull+create latency.
WARM_POOL_SIZE=0
# Image to pre-start. Must match the image callers request.
WARM_POOL_IMAGE=

# ── GPU runner support ─────────────────────────────────────────────────────────
# Set to "all" to expose all NVIDIA GPUs, or a specific device ID (e.g. "GPU-uuid").
# Requires the NVIDIA Container Toolkit on the host.
# Callers set gpu_enabled=true when creating a session to request GPU access.
DOCKER_GPU_DEVICES=

# ── Session resource limits ───────────────────────────────────────────────────
MAX_SESSION_CPU=8
MAX_SESSION_MEMORY_MB=8192
MAX_SESSION_TIMEOUT_SEC=86400
# Maximum concurrent sessions per API key actor. 0 = unlimited.
MAX_SESSIONS_PER_ACTOR=20

# ── Workspace ─────────────────────────────────────────────────────────────────
WORKSPACE_BASE_DIR=/data/workspaces
MAX_FILE_MB=100
MAX_OUTPUT_MB=10
# Total workspace size cap per session (0 = unlimited)
MAX_WORKSPACE_MB=0

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
# Used only to create the first API key. Rotate or disable after bootstrapping.
MASTER_API_KEY=
# Path to a Rego policy file for per-command allow/deny decisions. Empty = AllowAll.
OPA_POLICY_FILE=

# ── Secrets broker ────────────────────────────────────────────────────────────
# Backend provider: "env" (default), "vault" (HashiCorp Vault), or "aws" (AWS Secrets Manager).
SECRETS_PROVIDER=env
# HashiCorp Vault (required when SECRETS_PROVIDER=vault)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=
VAULT_MOUNT=secret
VAULT_PATH=vaultrun
# AWS Secrets Manager (required when SECRETS_PROVIDER=aws)
# Uses standard AWS credentials (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN).
# AWS_REGION must also be set.
SECRETS_AWS_PREFIX=vaultrun/
# Env provider: prefix for secret env vars (VAULTRUN_SECRET_<NAME>).
# e.g. VAULTRUN_SECRET_DB_PASSWORD=hunter2 → secret name "DB_PASSWORD"

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
# HMAC-SHA256 key for signing async run callback payloads (X-VaultRun-Signature header).
# Generate with: openssl rand -hex 32. Empty = no signing (insecure for internet-facing callbacks).
WEBHOOK_SECRET=
# Audit log retention — entries older than N days are deleted by the cleanup sweep.
# 0 = keep forever. Default: 90 days.
AUDIT_LOG_RETENTION_DAYS=90
STOP_CONTAINERS_ON_SHUTDOWN=false
# SIEM / enterprise audit export: set to an HTTP endpoint to receive newline-delimited JSON.
# New audit entries are polled every 30s and POSTed as application/x-ndjson.
AUDIT_EXPORT_URL=
# Bearer token sent in Authorization header to the SIEM endpoint.
AUDIT_EXPORT_SECRET=

# ── Migrations ────────────────────────────────────────────────────────────────
MIGRATIONS_PATH=migrations

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── CLI / SDK ─────────────────────────────────────────────────────────────────
VAULTRUN_API_URL=http://localhost:8080
VAULTRUN_API_KEY=
