# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
GIN_MODE=debug

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://vaultrun:vaultrun@localhost:5432/vaultrun?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# ── Redis ────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Docker sandbox ───────────────────────────────────────────
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_CONTAINER_PREFIX=vaultrun
DOCKER_DEFAULT_IMAGE=python:3.12-slim
DOCKER_IDLE_TIMEOUT_MINS=30

# ── Workspace ────────────────────────────────────────────────
WORKSPACE_BASE_DIR=/data/workspaces
MAX_FILE_MB=100
MAX_OUTPUT_MB=10

# ── Auth ─────────────────────────────────────────────────────
# Master key is used to bootstrap the first API key. Set to a strong random value.
# After creating your first key via POST /api/v1/keys, you can leave this empty.
MASTER_API_KEY=changeme-master-key

# ── Migrations ───────────────────────────────────────────────
MIGRATIONS_PATH=migrations

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── CLI / SDK ────────────────────────────────────────────────
VAULTRUN_API_URL=http://localhost:8080
VAULTRUN_API_KEY=your-api-key-here
